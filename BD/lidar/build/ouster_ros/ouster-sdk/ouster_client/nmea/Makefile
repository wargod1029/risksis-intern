	cd /home/risksis/Documents/intern/ROS_noetic/ouster_humble_ws/build/ouster_ros && $(CMAKE_COMMAND) -S$(CMAKE_SOURCE_DIR) -B$(CMAKE_BINARY_DIR) --check-build-system CMakeFiles/Makefile.cmake 0
